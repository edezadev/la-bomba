<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="ButtonOutlineStyleMedium" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeWidth">@dimen/outline_width</item>
        <item name="android:textAppearance">?attr/textAppearanceHeadlineSmall</item>
        <item name="rippleColor">@color/ripple</item>
    </style>

    <style name="ButtonOutlineStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="rippleColor">@color/ripple</item>
    </style>

    <style name="PopupMenuStyle" parent="Widget.Material3.PopupMenu">
        <item name="android:textColor">?colorOnSurfaceVariant</item>
    </style>

    <style name="LoadingDialogStyle" parent="Theme.Material3.DayNight.Dialog">
        <!--Configura la opacidad del fondo de la pantalla del dialogo-->
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>
</resources>