<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_splash_logo</item>
        <item name="postSplashScreenTheme">@style/Theme.LaBomba</item>
    </style>

    <style name="ButtonOutlineStyleMedium" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeWidth">@dimen/outline_width</item>
        <item name="android:textAppearance">?attr/textAppearanceHeadlineSmall</item>
        <item name="rippleColor">@color/ripple</item>
    </style>

    <style name="ButtonOutlineStyle" parent="Widget.Material3.Button.OutlinedButton">
        <item name="rippleColor">@color/ripple</item>
    </style>

    <style name="CustomTextAppearanceBodyLarge" parent="TextAppearance.Material3.BodyLarge">
        <item name="android:textColor">?attr/colorOnSurfaceVariant</item>
    </style>

    <style name="CustomMaterialDialogTheme" parent="ThemeOverlay.Material3.MaterialAlertDialog">
        <item name="android:backgroundTint">?attr/colorSurfaceVariant</item>
    </style>

    <style name="CustomModalBottomSheetDialog" parent="ThemeOverlay.Material3.BottomSheetDialog">
        <item name="bottomSheetStyle">@style/ModalBottomSheetDialogStyle</item>
    </style>
    <style name="ModalBottomSheetDialogStyle" parent="Widget.Material3.BottomSheet.Modal">
        <item name="backgroundTint">?attr/colorSurfaceVariant</item>
    </style>

    <style name="LoadingDialogStyle" parent="Theme.Material3.DayNight.Dialog">
        <!--Configura la opacidad del fondo de la pantalla del dialogo-->
        <item name="android:backgroundDimEnabled">true</item>
        <item name="android:backgroundDimAmount">0.7</item>
    </style>
</resources>